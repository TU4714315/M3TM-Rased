rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null && request.auth.token.email != null;
    }

    function bootstrapAdmin() {
      return signedIn() && request.auth.token.email in [
        'moooom001@hotmail.com',
        'mohammed.e.z.m2@gmail.com'
      ];
    }

    function profilePath() {
      return /databases/$(database)/documents/users/$(request.auth.uid);
    }

    function hasActiveProfile() {
      return signedIn()
        && exists(profilePath())
        && get(profilePath()).data.active == true;
    }

    function role() {
      return bootstrapAdmin()
        ? 'admin'
        : (hasActiveProfile() ? get(profilePath()).data.role : 'none');
    }

    function authorized() {
      return bootstrapAdmin() || hasActiveProfile();
    }

    function admin() {
      return role() == 'admin';
    }

    function contentManager() {
      return role() in ['admin', 'manager'];
    }

    function validRole(value) {
      return value in ['admin', 'manager', 'user'];
    }

    function validNews() {
      return request.resource.data.keys().hasAll([
        'title', 'sourceName', 'url', 'category', 'importance',
        'summary', 'fingerprint', 'publishedAt', 'createdAt', 'createdBy'
      ])
      && request.resource.data.title is string
      && request.resource.data.title.size() > 0
      && request.resource.data.title.size() <= 180
      && request.resource.data.sourceName is string
      && request.resource.data.sourceName.size() <= 120
      && request.resource.data.url is string
      && request.resource.data.url.size() <= 2048
      && request.resource.data.category is string
      && request.resource.data.category.size() <= 80
      && request.resource.data.summary is string
      && request.resource.data.summary.size() <= 2000
      && request.resource.data.importance in ['low', 'medium', 'high', 'critical'];
    }

    function validSource() {
      return request.resource.data.keys().hasAll([
        'name', 'feedUrl', 'siteUrl', 'category', 'status',
        'createdAt', 'updatedAt', 'createdBy'
      ])
      && request.resource.data.name is string
      && request.resource.data.name.size() > 0
      && request.resource.data.name.size() <= 140
      && request.resource.data.feedUrl is string
      && request.resource.data.feedUrl.size() > 0
      && request.resource.data.feedUrl.size() <= 2048
      && request.resource.data.siteUrl is string
      && request.resource.data.siteUrl.size() <= 2048
      && request.resource.data.category is string
      && request.resource.data.category.size() <= 80
      && request.resource.data.status in ['active', 'paused', 'error'];
    }

    function validSettings() {
      return request.resource.data.keys().hasAll([
        'platformName', 'defaultCategory', 'feedSyncEnabled', 'updatedAt', 'updatedBy'
      ])
      && request.resource.data.platformName is string
      && request.resource.data.platformName.size() > 0
      && request.resource.data.platformName.size() <= 80
      && request.resource.data.defaultCategory is string
      && request.resource.data.defaultCategory.size() > 0
      && request.resource.data.defaultCategory.size() <= 80
      && request.resource.data.feedSyncEnabled is bool
      && request.resource.data.updatedBy == request.auth.uid;
    }

    function validIntelligenceSource() {
      return request.resource.data.keys().hasAll([
        'name', 'type', 'url', 'provider', 'category', 'language',
        'priority', 'enabled', 'fetchIntervalMinutes', 'createdAt',
        'updatedAt', 'createdBy'
      ])
      && request.resource.data.name is string
      && request.resource.data.name.size() > 0
      && request.resource.data.name.size() <= 160
      && request.resource.data.url is string
      && request.resource.data.url.size() > 0
      && request.resource.data.url.size() <= 2048
      && request.resource.data.provider in [
        'rss', 'gdelt', 'hackernews', 'github', 'newsapi', 'cisa_kev', 'custom'
      ]
      && request.resource.data.priority is int
      && request.resource.data.priority >= 0
      && request.resource.data.priority <= 100
      && request.resource.data.enabled is bool
      && request.resource.data.fetchIntervalMinutes is int
      && request.resource.data.fetchIntervalMinutes >= 15
      && request.resource.data.fetchIntervalMinutes <= 1440;
    }

    function validWatchlist() {
      return request.resource.data.keys().hasAll([
        'name', 'type', 'keywords', 'entities', 'enabled',
        'notifyChannels', 'createdBy', 'createdAt', 'updatedAt'
      ])
      && request.resource.data.name is string
      && request.resource.data.name.size() > 0
      && request.resource.data.name.size() <= 160
      && request.resource.data.type in [
        'mixed', 'news', 'repository', 'دولة', 'شركة', 'جهة حكومية',
        'شخص', 'دومين', 'بريد', 'CVE', 'جماعة/فصيل', 'كلمة مفتاحية',
        'مستودع GitHub', 'مصدر إخباري'
      ]
      && request.resource.data.keywords is list
      && request.resource.data.keywords.size() <= 100
      && request.resource.data.entities is list
      && request.resource.data.entities.size() <= 100
      && request.resource.data.notifyChannels is list
      && request.resource.data.enabled is bool;
    }

    match /users/{uid} {
      allow get: if signedIn() && (uid == request.auth.uid || admin());
      allow list: if admin();
      allow create: if signedIn()
        && uid == request.auth.uid
        && request.resource.data.email == request.auth.token.email
        && request.resource.data.active == true
        && validRole(request.resource.data.role)
        && (
          (bootstrapAdmin() && request.resource.data.role == 'admin')
          ||
          (
            exists(/databases/$(database)/documents/invites/$(request.auth.token.email))
            && get(/databases/$(database)/documents/invites/$(request.auth.token.email)).data.status == 'pending'
            && request.resource.data.role ==
              get(/databases/$(database)/documents/invites/$(request.auth.token.email)).data.role
          )
        );
      allow update, delete: if admin();
    }

    match /invites/{email} {
      allow get: if signedIn() && (email == request.auth.token.email || admin());
      allow list, create, delete: if admin();
      allow update: if admin()
        || (
          signedIn()
          && email == request.auth.token.email
          && resource.data.status == 'pending'
          && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['status', 'acceptedAt'])
          && request.resource.data.status == 'accepted'
        );
    }

    match /news/{docId} {
      allow read: if authorized();
      allow create, update: if contentManager() && validNews();
      allow delete: if contentManager();
    }

    match /sources/{docId} {
      allow read: if authorized();
      allow create, update: if contentManager() && validSource();
      allow delete: if contentManager();
    }

    match /syncRuns/{docId} {
      allow read: if contentManager();
      allow write: if false;
    }

    match /syncRequests/{docId} {
      allow read: if contentManager();
      allow create: if contentManager()
        && request.resource.data.requestedBy == request.auth.uid
        && request.resource.data.status == 'pending';
      allow update, delete: if false;
    }

    match /settings/{docId} {
      allow read: if authorized();
      allow create, update: if admin() && docId == 'general' && validSettings();
      allow delete: if false;
    }

    match /news_items/{docId} {
      allow read: if authorized();
      allow update: if contentManager()
        && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['summary', 'summary_ar', 'status', 'updatedAt']);
      allow create, delete: if false;
    }

    match /grey_intel_items/{docId} {
      allow read: if authorized();
      allow create, update, delete: if false;
    }

    match /news_sources/{docId} {
      allow read: if authorized();
      allow create, update: if contentManager() && validIntelligenceSource();
      allow delete: if contentManager();
    }

    match /news_bookmarks/{docId} {
      allow read: if authorized() && resource.data.userId == request.auth.uid;
      allow create: if authorized()
        && request.resource.data.userId == request.auth.uid
        && docId == request.auth.uid + '_' + request.resource.data.newsId;
      allow delete: if authorized() && resource.data.userId == request.auth.uid;
      allow update: if false;
    }

    match /grey_bookmarks/{docId} {
      allow read: if authorized() && resource.data.userId == request.auth.uid;
      allow create: if authorized()
        && request.resource.data.userId == request.auth.uid
        && docId == request.auth.uid + '_' + request.resource.data.itemId;
      allow delete: if authorized() && resource.data.userId == request.auth.uid;
      allow update: if false;
    }

    match /news_fetch_logs/{docId} {
      allow read: if contentManager();
      allow write: if false;
    }

    match /repo_intelligence_items/{docId} {
      allow read: if authorized();
      allow update: if contentManager()
        && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['saved', 'usefulIdeas', 'implementationPriority', 'updatedAt']);
      allow create, delete: if false;
    }

    match /watchlists/{docId} {
      allow read: if authorized()
        && (contentManager() || resource.data.createdBy == request.auth.uid);
      allow create: if authorized()
        && request.resource.data.createdBy == request.auth.uid
        && validWatchlist();
      allow update: if authorized()
        && (contentManager() || resource.data.createdBy == request.auth.uid)
        && validWatchlist();
      allow delete: if authorized()
        && (contentManager() || resource.data.createdBy == request.auth.uid);
    }

    match /watchlist_hits/{docId} {
      allow read: if authorized();
      allow write: if false;
    }

    match /alerts/{docId} {
      allow read: if authorized();
      allow update: if authorized()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']);
      allow create, delete: if false;
    }

    match /tasks/{docId} {
      allow read: if authorized()
        && (contentManager() || resource.data.createdBy == request.auth.uid);
      allow create: if authorized()
        && request.resource.data.createdBy == request.auth.uid;
      allow update, delete: if authorized()
        && (contentManager() || resource.data.createdBy == request.auth.uid);
    }

    match /reports/{docId} {
      allow read: if authorized()
        && (contentManager() || resource.data.createdBy == request.auth.uid);
      allow create: if authorized()
        && request.resource.data.createdBy == request.auth.uid;
      allow update, delete: if authorized()
        && (contentManager() || resource.data.createdBy == request.auth.uid);
    }

    match /intelligence_reports/{docId} {
      allow read: if authorized()
        && (contentManager() || resource.data.createdBy == request.auth.uid);
      allow create: if authorized()
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.legalNotice is string;
      allow update, delete: if authorized()
        && (contentManager() || resource.data.createdBy == request.auth.uid);
    }

    match /intelligence_requests/{docId} {
      allow read: if contentManager();
      allow create: if contentManager()
        && request.resource.data.requestedBy == request.auth.uid
        && request.resource.data.status == 'pending'
        && request.resource.data.type in ['refresh', 'seed-arabic', 'seed-grey']
        && request.resource.data.scope in ['all', 'arabic', 'grey'];
      allow update, delete: if false;
    }

    match /audit_logs/{docId} {
      allow read: if admin();
      allow create: if contentManager()
        && request.resource.data.actorId == request.auth.uid;
      allow update, delete: if false;
    }

    match /audit_events/{docId} {
      allow read: if admin();
      allow create: if contentManager()
        && request.resource.data.actorId == request.auth.uid;
      allow update, delete: if false;
    }

    match /source_reliability_scores/{docId} {
      allow read: if authorized();
      allow write: if false;
    }

    match /entities/{docId} {
      allow read: if authorized();
      allow write: if false;
    }

    match /topics/{docId} {
      allow read: if authorized();
      allow write: if false;
    }

    match /repository_ideas/{docId} {
      allow read: if authorized()
        && (contentManager() || resource.data.createdBy == request.auth.uid);
      allow create: if authorized()
        && request.resource.data.createdBy == request.auth.uid;
      allow update, delete: if authorized()
        && (contentManager() || resource.data.createdBy == request.auth.uid);
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
